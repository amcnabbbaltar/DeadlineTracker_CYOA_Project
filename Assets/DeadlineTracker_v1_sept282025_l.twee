:: Story JavaScript
/* ====== Helpers (globals) ====== */
(function () {
  // Robust parse of a minute cost from number or string ("4", "+4", "-9", "foo 12 bar").
  function parseCost(x) {
    if (typeof x === 'number') return x | 0;
    const m = String(x).match(/-?\d+/);
    return m ? parseInt(m[0], 10) : 0;
  }
  if (typeof window._evalCost !== 'function') {
    window._evalCost = parseCost;           // ensure it's a function
  }

  // Clock formatters (also mirrored to setup).
  window.formatClock = window.formatClock || function (mins) {
    const base = new Date(2000, 0, 1, 0, 0, 0);
    base.setMinutes((mins | 0));
    const h  = base.getHours();
    const m  = String(base.getMinutes()).padStart(2, '0');
    const hh = (h % 12) === 0 ? 12 : (h % 12);
    const ap = h < 12 ? 'AM' : 'PM';
    return hh + ':' + m + ' ' + ap;
  };
  window.formatHMM = window.formatHMM || function (mins) {
    mins = Math.max(0, mins | 0);
    return Math.floor(mins / 60) + 'h ' + String(mins % 60).padStart(2, '0') + 'm';
  };
  window.grey = window.grey || (s => '<span style="opacity:.55">' + s + '</span>');

  // For prose mentions of the deadline time (5:00 AM).
  window.deadlineClock = window.deadlineClock || function () {
    try { return window.formatClock(State.variables.deadline | 0); }
    catch (e) { return '5:00 AM'; }
  };

  // Expose helpers under `setup` so TwineScript can call them.
  window.setup = window.setup || {};
  setup.formatClock   = window.formatClock;
  setup.formatHMM     = window.formatHMM;
  setup.deadlineClock = window.deadlineClock;

  // ====== Scene image swap + small title clock ======
  jQuery(document).on(':passagedisplay', function (ev) {
    let base = (ev && ev.passage && ev.passage.title) ? ev.passage.title : '';
    if (base.includes('{'))      base = base.split('{', 1)[0];
    if (base.includes('&#123;')) base = base.split('&#123;', 1)[0];
    base = base.trim();

    const slug = base.toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)/g, '');

    const $img = jQuery('#scene');
    if ($img.length) {
      const src = 'assets/deadline/' + slug + '.png';
      $img.attr('alt', base ? ('scene: ' + base) : 'scene')
          .attr('src', src)
          .one('error', () => $img.attr('src', 'assets/deadline/start.png'));
    }

    try {
      const V = State.variables || {};
      document.title = V.hudEnabled
        ? ('DEADline: ' + setup.formatClock(V.time || 0))
        : 'DEADline';
    } catch (e) { /* noop */ }
  });
  
  // Defaults on story start.
  jQuery(document).one(':storyready', function () {
    try {
      const V = State.variables;
      if (V.deadline == null) V.deadline = 300;  // 5:00 AM
      if (V.hudEnabled == null) V.hudEnabled = false;
      if (V._introAnchored == null) V._introAnchored = false;
      if (!V._introAnchored && (V.time == null || V.time < 15)) {
        V.time = 15; // 12:15 AM anchor
        V._introAnchored = true;
      }
    } catch (e) { console.warn('[storyready init]', e); }
  });
})();

