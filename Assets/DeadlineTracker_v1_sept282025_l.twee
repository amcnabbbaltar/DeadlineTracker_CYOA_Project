:: Story Stylesheet
/* Load fonts here (no <link> tags needed) */
@import url('https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@0;1&family=Spectral:wght@400;600&display=swap');

:root{
  --paper:#f7f6f1;
  --ink:#0a0a0a;
  --soot:#222;
  --line:#111;
  --ash:#666;
  --accent:#7a7a7a;
  --frame:#0a0a0a;
  --shadow: rgba(0,0,0,.35);
  --ring:#bdbdbd;
  --max: 72ch;
}

/* Page */
html,body{height:100%;margin:0;background:var(--ink);color:var(--paper);}

/* Background texture */
#story{
  min-height:100%;
  display:flex;flex-direction:column;justify-content:center;align-items:center;
  padding:2rem .75rem;
  background:
    radial-gradient(1200px 800px at 20% 10%, rgba(255,255,255,.05), transparent 60%),
    radial-gradient(1000px 600px at 80% 90%, rgba(255,255,255,.04), transparent 60%),
    repeating-linear-gradient(0deg, rgba(0,0,0,.02) 0 2px, transparent 2px 4px);
}

/* Scene frame */
#scene{
  width:min(95vw,640px);
  filter: grayscale(100%) contrast(105%);
  border:6px solid var(--frame);
  outline:10px double var(--ink);
  box-shadow:0 0 0 6px var(--paper) inset, 0 12px 28px var(--shadow);
  margin-bottom:1.5rem;
  background:#fff;
  display:block;
}

/* Passage body panel */
#passages{
  max-width:var(--max);
  background:var(--paper);
  color:var(--line);
  font-family:"Spectral", serif;
  font-size:1.15rem;
  line-height:1.6;
  padding:1.75rem 2.25rem;
  border:4px solid var(--line);
  outline:8px solid var(--ink);
  box-shadow:0 10px 24px var(--shadow);
}

/* Headings */
#passages h1,#passages h2,#passages h3{
  font-family:"IM Fell English", serif;
  color:var(--line);
  margin-top:0;
  letter-spacing:.02em;
  text-transform:uppercase;
}

/* Emphasis */
#passages strong{color:var(--ink);}
#passages em{color:var(--ash);}

/* Quotes */
#passages blockquote{
  margin:0 0 1rem 0;
  padding-left:1rem;
  border-left:4px solid var(--ink);
  color:var(--line);
}

/* Links */
#passages a.link-internal{
  color:var(--ink);
  text-decoration:underline;
  text-decoration-thickness:2px;
  text-underline-offset:2px;
}
#passages a.link-internal:hover{
  color:var(--soot);
  text-decoration-style:dotted;
}

/* Principle scrolls */
.principle-scroll{
  border:2px solid var(--line);
  background:#faf7f0;
  padding:1rem 1.25rem;
  margin:1rem 0 1.25rem;
  box-shadow:0 2px 4px var(--shadow);
  font-family:"IM Fell English", serif;
}

/* A11y + motion */
:focus-visible { outline: 2px solid var(--ring); outline-offset: 2px; }
@media (prefers-reduced-motion: reduce) { * { transition: none !important; animation: none !important; } }

@media(max-width:600px){
  #scene{width:98vw}
  #passages{padding:1.25rem;font-size:1.05rem}
}

/* Principle HUD (inline, under scene image) */
/* Principle HUD (inline, under scene image) */
.principle-hud-inline{
  position:static;
  background:#faf7f0;
  color:var(--line);
  border:1px solid var(--line);
  border-radius:6px;
  padding:.5rem .75rem;
  box-shadow:none;
  max-width:100%;
  margin:.35rem 0 .75rem 0;
  line-height:1.25;
}
.principle-hud-inline *{margin:0;padding:0;line-height:1.2}
.principle-hud-inline strong{display:block;font-weight:600;margin:0 0 .15rem 0}
.principle-hud-inline table{border-collapse:collapse;width:auto}
.principle-hud-inline td{padding:0 .5rem .1rem 0;vertical-align:top}
.principle-hud-inline td.k{opacity:.9;min-width:120px}
.principle-hud-inline .k{opacity:.9;min-width:100px}
.principle-hud-inline .v{opacity:1;font-weight:600}

:: UI_Macros [script]
/* timelink macro: placed in a [script]-tagged passage for maximum compatibility with SugarCube load order */
(function () {
  if (typeof Macro !== 'undefined' && (!Macro.get || !Macro.get('timelink'))) {
    Macro.add('timelink', {
      tags : null,
      handler : function () {
        if (this.args.length < 3) {
          return this.error('Usage: <<timelink "Label" cost "Passage">> [payload] <</timelink>>');
        }
        let   label   = String(this.args[0]);
        const costArg = this.args[1];
        const target  = String(this.args[2]);
        const payload = (this.payload && this.payload[0]) ? this.payload[0].contents : '';
        const num = (v) => (typeof v === 'number' && isFinite(v)) ? (v|0) : 0;
        const parseCost = (x) => {
          if (typeof x === 'number') return x|0;
          const m = String(x).match(/-?\d+/);
          return m ? parseInt(m[0], 10) : 0;
        };
        const tryTwine = (expr) => {
          try {
            if (typeof Scripting !== 'undefined' && Scripting.evalTwineScript) {
              const opt = { variables : State && State.variables, temp : State && State.temporary, context : this.context || undefined };
              const v = Scripting.evalTwineScript(expr, opt);
              if (typeof v === 'number' && isFinite(v)) return v|0;
            }
          } catch (e) {}
          return null;
        };
        const substituteVars = (s) => {
          s = s.replace(/\$[A-Za-z_]\w*/g, (m) => {
            const k = m.slice(1);
            const v = State && State.variables ? State.variables[k] : undefined;
            return (typeof v === 'number' && isFinite(v)) ? String(v|0) : '0';
          });
          s = s.replace(/_[A-Za-z]\w*/g, (m) => {
            const k = m.slice(1);
            const v = State && State.temporary ? State.temporary[k] : undefined;
            return (typeof v === 'number' && isFinite(v)) ? String(v|0) : '0';
          });
          return s;
        };
        const safeArith = (s) => {
          if (!/^[\d\+\-\*\/%\(\)\s]+$/.test(s)) return null;
          try { const v = Function('return (' + s + ')')(); return (typeof v === 'number' && isFinite(v)) ? (v|0) : null; }
          catch (e) { return null; }
        };
        const evalCost = (expr) => {
          if (typeof expr === 'number') return expr|0;
          let s = String(expr).trim();
          if (/^-?\d+$/.test(s)) return parseInt(s, 10);
          let v = tryTwine(s); if (v !== null) return v;
          const sub = substituteVars(s); v = safeArith(sub); if (v !== null) return v;
          return parseCost(s);
        };
        const shownCost = Math.max(0, num(evalCost(costArg)));
        label = label.replace(/\s*\(\+\s*\d+\s*m\)\s*$/i, '');
        const finalLabel = label + ' (+' + shownCost + 'm)';
        const $a = jQuery('<a/>').addClass('link-internal passage-link').attr('role','link').text(finalLabel);
        $a.on('click', () => {
          try {
            const V = State.variables;
            const live = Math.max(0, num(evalCost(costArg)));
            V.time = (V.time|0) + live;
            if (payload) { const tmp = document.createElement('div'); new Wikifier(tmp, payload); }
            Engine.play(target);
          } catch (e) { console.error('[timelink] click error', e); }
          return false;
        });
        jQuery(this.output).append($a);
      }
    });
    try { console.log('[timelink] macro registered [UI_Macros]'); } catch(e){}
  }
})();

/* ====== <<timelink "Label" costExpr "Passage">> [payload] <</timelink>> ======
   Robust evaluation:
   - number (e.g. 4) → 4
   - string digits ("9") → 9
   - TwineScript expr ("_grab - _assist") → evaluated with temp/_ and $ support
   - Falls back to 0 on any error; labels and clicks stay consistent.
*/
(function () {
  if (typeof Macro !== 'undefined' && !Macro.get('timelink')) {
    Macro.add('timelink', {
      tags : null,

      handler : function () {
        if (this.args.length < 3) {
          return this.error('Usage: <<timelink "Label" cost "Passage">> [payload] <</timelink>>');
        }
        let   label   = String(this.args[0]);
        const costArg = this.args[1];
        const target  = String(this.args[2]);
        const payload = (this.payload && this.payload[0]) ? this.payload[0].contents : '';

        // ---- helpers ----
        const num = (v) => (typeof v === 'number' && isFinite(v)) ? (v|0) : 0;
        const parseCost = (x) => {
          if (typeof x === 'number') return x|0;
          const m = String(x).match(/-?\d+/);
          return m ? parseInt(m[0], 10) : 0;
        };
        const tryTwine = (expr) => {
          try {
            if (typeof Scripting !== 'undefined' && Scripting.evalTwineScript) {
              // hand in known scopes; tolerate missing props
              const opt = {
                variables : State && State.variables,
                temp      : State && State.temporary,
                // SugarCube doesn’t require this, but pass what we can:
                context   : this.context || undefined
              };
              const v = Scripting.evalTwineScript(expr, opt);
              if (typeof v === 'number' && isFinite(v)) return v|0;
            }
          } catch (e) {}
          return null;
        };
        const substituteVars = (s) => {
          // Replace $foo and _bar with their numeric values (or 0 if not numeric).
          s = s.replace(/\$[A-Za-z_]\w*/g, (m) => {
            const k = m.slice(1);
            const v = State && State.variables ? State.variables[k] : undefined;
            return (typeof v === 'number' && isFinite(v)) ? String(v|0) : '0';
          });
          s = s.replace(/_[A-Za-z]\w*/g, (m) => {
            const k = m.slice(1);
            const v = State && State.temporary ? State.temporary[k] : undefined;
            return (typeof v === 'number' && isFinite(v)) ? String(v|0) : '0';
          });
          return s;
        };
        const safeArith = (s) => {
          // Only allow digits, + - * / % ( ) and whitespace.
          if (!/^[\d\+\-\*\/%\(\)\s]+$/.test(s)) return null;
          try {
            // eslint-disable-next-line no-new-func
            const v = Function('return (' + s + ')')();
            return (typeof v === 'number' && isFinite(v)) ? (v|0) : null;
          } catch (e) { return null; }
        };
        const evalCost = (expr) => {
          if (typeof expr === 'number') return expr|0;
          let s = String(expr).trim();
          if (/^-?\d+$/.test(s)) return parseInt(s, 10);

          // 1) Try TwineScript directly
          let v = tryTwine(s);
          if (v !== null) return v;

          // 2) Substitute variables and evaluate arithmetic safely
          const sub = substituteVars(s);
          v = safeArith(sub);
          if (v !== null) return v;

          // 3) Last resort: pull first number
          return parseCost(s);
        };

        // ---- label (always shows a sane number) ----
        const shownCost = Math.max(0, num(evalCost(costArg)));
        label = label.replace(/\s*\(\+\s*\d+\s*m\)\s*$/i, ''); // strip any manual (+Xm)
        const finalLabel = label + ' (+' + shownCost + 'm)';

        const $a = jQuery('<a/>')
          .addClass('link-internal passage-link')
          .attr('role', 'link')
          .text(finalLabel);

        // ---- click: update time with the same evaluation logic (safely) ----
        $a.on('click', () => {
          try {
            const V = State.variables;
            const live = Math.max(0, num(evalCost(costArg)));
            const base = (V.time|0);
            V.time = base + live;

            if (payload) {
              const tmp = document.createElement('div');
              new Wikifier(tmp, payload); // execute silently
            }
            Engine.play(target);
          } catch (e) {
            console.error('[timelink] click error', e);
          }
          return false;
        });

        jQuery(this.output).append($a);
      }
    });
  console.log('[timelink] macro registered');
  } else {
  console.log('[timelink] macro already present or Macro API missing');
  }
})();


/* Principle HUD (playtest overlay) */
(function(){
  'use strict';
  function ensurePanel(){
    let $panel = jQuery('#principle-hud');
    if (!$panel.length){ $panel = jQuery('<div id="principle-hud" aria-live="polite"></div>').appendTo('body'); }
    return $panel;
  }
  function fmtPlan(s){
    if (!s) return 'None';
    if (s === 'schedule') return 'Schedule';
    if (s === 'buffer') return 'Buffer';
    if (s === 'top3') return 'Top 3';
    return s;
  }
  jQuery(document).on(':passagedisplay', function(){
    // Disable overlay HUD; use inline PassageFooter HUD instead
    jQuery('#principle-hud').remove();
    return;
  });
})();




 




