/* CLOCK + UTIL HELPERS (run at game load, before any passage renders) */
<<script>>
window.setup = window.setup || {};

/* Display helpers used in <<= … >> */
setup.formatClock = setup.formatClock || function (mins) {
  const base = new Date(2000, 0, 1, 0, 0, 0);
  base.setMinutes((mins | 0));
  const h  = base.getHours();
  const m  = String(base.getMinutes()).padStart(2, '0');
  const hh = (h % 12) === 0 ? 12 : (h % 12);
  const ap = h < 12 ? 'AM' : 'PM';
  return hh + ':' + m + ' ' + ap;
};
setup.formatHMM = setup.formatHMM || function (mins) {
  mins = Math.max(0, mins | 0);
  return Math.floor(mins / 60) + 'h ' + String(mins % 60).padStart(2, '0') + 'm';
};
setup.deadlineClock = setup.deadlineClock || function () {
  try { return setup.formatClock(State.variables.deadline | 0); }
  catch (e) { return '5:00 AM'; }
};

/* Keep window aliases too (for any JS that calls window.*) */
window.formatClock    = setup.formatClock;
window.formatHMM      = setup.formatHMM;
window.deadlineClock  = setup.deadlineClock;

/* tiny util */
window.grey = window.grey || (s => '<span style="opacity:.55">'+ s +'</span>');
<</script>>


